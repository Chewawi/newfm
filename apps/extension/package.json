{
	"name": "@/extension",
	"displayName": "Extension",
	"version": "0.0.1",
	"description": "A basic Plasmo extension.",
	"author": "Chewawi",
	"scripts": {
		"dev": "plasmo dev",
		"build": "plasmo build",
		"package": "plasmo package",
		"fmt": "biome format --write .",
		"lint": "biome lint .",
		"check": "tsc --noEmit"
	},
	"dependencies": {
		"dotenv": "^17.4.2",
		"plasmo": "0.90.5",
		"react": "18.2.0",
		"react-dom": "18.2.0",
		"types": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/chrome": "0.0.258",
		"@types/node": "20.11.5",
		"@types/react": "18.2.48",
		"@types/react-dom": "18.2.18",
		"typescript": "5.3.3"
	},
	"manifest": {
		"permissions": [
			"storage"
		],
		"host_permissions": [
			"https://*/*"
		]
	}
}
