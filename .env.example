# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/newfm

# Redis
REDIS_URL=redis://127.0.0.1:6379

# API server bind address
BIND_ADDR=0.0.0.0:8080

# Logging (see tracing-subscriber docs)
# newfm=debug shows app logs, sqlx=warn hides query noise, tower_http=debug shows HTTP logs
RUST_LOG=newfm=debug,sqlx=warn,tower_http=debug

# Postgres pool size (optional, default: 20)
# DB_MAX_CONNECTIONS=20
